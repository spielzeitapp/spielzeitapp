# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (MVP): npx web-push generate-vapid-keys → Public Key hier, Private Key nur serverseitig (Vercel)
VITE_VAPID_PUBLIC_KEY=
# Optional: volle URL, wenn die API nicht unter derselben Origin liegt
# VITE_PUSH_API_URL=https://deine-app.vercel.app/api/push/subscribe

# Nur Server (Vercel Environment Variables) – niemals im Frontend
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Reminder-Dispatch POST /api/notifications/dispatch (Cron / Vercel)
# CRON_SECRET=
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=   (kann = VITE_VAPID_PUBLIC_KEY sein)
# VAPID_CONTACT_EMAIL=mailto:team@example.com
# Optional:
# NOTIFICATION_TRAINING_REMINDER_HOUR=11
# NOTIFICATION_TRAINING_WINDOW_END_HOUR=12
# NOTIFICATION_GAME_REMINDER_DAYS=7

# Admin Setup: Code wird in der Edge Function "setup-admin" geprüft (Secret ADMIN_SETUP_CODE im Supabase Dashboard).
# VITE_ADMIN_SETUP_CODE wird im Frontend nicht mehr verwendet (Validierung nur noch in der Edge Function).
